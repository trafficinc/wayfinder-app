{
    "name": "wayfinder/app",
    "description": "Default application skeleton for the Wayfinder framework.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "wayfinder/core": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/trafficinc/wayfinder-core"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
